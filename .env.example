# LLM for Receipt Analysis Agent + Explain Agent
# Copy to .env locally, or add these in Railway → Variables

OPENAI_API_KEY=sk-your-key-here

# Optional: use Azure OpenAI, Groq, or other OpenAI-compatible API
# LLM_API_KEY=your-key
# LLM_BASE_URL=https://api.groq.com/openai/v1

# Model (vision-capable models work best for receipt images)
LLM_MODEL=gpt-4o-mini

# Send receipt images to the model (true recommended)
USE_LLM_VISION=true
